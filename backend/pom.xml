            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-api</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-biz</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-bo</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-boot</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-common</artifactId>
                <version>${revision}</version>
            </dependency>

