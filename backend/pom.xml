            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-ao</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-api</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-biz</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-bo</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-boot</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-common</artifactId>
                <version>${revision}</version>
            </dependency>

