            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>user-service</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>order-service</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>airplane-service</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- Auth Service -->
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>auth-ao</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>auth-api</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>top.flowerstardream.atbs</groupId>
                <artifactId>auth-biz</artifactId>
                <version>${revision}</version>
