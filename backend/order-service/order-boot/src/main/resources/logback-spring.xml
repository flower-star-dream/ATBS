<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 1. 把 Spring 属性读进来 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>

    <!-- 2. 控制台 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN:-%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n}</pattern>
        </encoder>
    </appender>

    <!-- 3. 文件（按天滚动） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前正在写的文件 -->
        <file>logs/${APP_NAME}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 历史文件 -->
            <fileNamePattern>logs/${APP_NAME}/${APP_NAME}-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 4. 级别配置（与 yml 完全一致） -->
    <logger name="top.flower.star.dream.hcd" level="DEBUG"/>
    <logger name="org.springframework.web" level="DEBUG"/>
    <logger name="com.alibaba.cloud.nacos" level="DEBUG"/>
    <logger name="org.springframework.cloud.gateway" level="DEBUG"/>
    <logger name="org.springframework.http.server.reactive" level="DEBUG"/>
    <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
    <logger name="org.apache.ibatis" level="DEBUG"/>
    <logger name="org.springdoc" level="DEBUG"/>
    <logger name="io.seata" level="DEBUG"/>

    <!-- 5. 根日志 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
